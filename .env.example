# =============================================================================
# llamacpp-agentified — Configuration
# =============================================================================

# Model to load (must match a config/models/*.json filename without extension)
MODEL_NAME=qwen3-4b

# Service
SERVICE_PORT=8080
COMPOSE_PROJECT_NAME=llamacpp
DATA_VOLUME_NAME=llamacpp-data
RESTART_POLICY=unless-stopped

# Resource limits
CPU_LIMIT=4
MEMORY_LIMIT=8g
GPU_COUNT=all

# GPU layers (-1 = all on GPU, 0 = CPU only)
GPU_LAYERS=-1
# GPU memory fraction (0.0-1.0, for sharing GPU between instances)
GPU_FRACTION=1.0

# Context length override (0 = use model config default)
CONTEXT_LENGTH=0
N_BATCH=512
N_THREADS=0
FLASH_ATTENTION=true

# Build args for GPU support (uncomment for CUDA)
# CMAKE_ARGS=-DGGML_CUDA=on
# FORCE_CMAKE=1

# HuggingFace token (for gated models)
# HF_TOKEN=hf_...
